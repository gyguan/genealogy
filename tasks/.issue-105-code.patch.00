+++ b/backend/genealogy-backend/src/main/java/com/genealogy/generation/entity/GenerationImportDraftEntity.java
@@ -0,0 +1,85 @@
+package com.genealogy.generation.entity;
+
+import jakarta.persistence.Column;
+import jakarta.persistence.Entity;
+import jakarta.persistence.GeneratedValue;
+import jakarta.persistence.GenerationType;
+import jakarta.persistence.Id;
+import jakarta.persistence.Table;
+import lombok.Getter;
+import lombok.Setter;
+
+import java.time.LocalDateTime;
+
+@Getter
+@Setter
+@Entity
+@Table(name = "generation_import_draft")
+public class GenerationImportDraftEntity {
+
+    public static final String TARGET_TYPE = "generation_import_draft";
+    public static final String ACTION_CREATE_SCHEME = "create_scheme";
+    public static final String ACTION_APPEND_WORD = "append_word";
+    public static final String STATUS_DRAFT = "draft";
+    public static final String STATUS_PENDING_REVIEW = "pending_review";
+    public static final String STATUS_OFFICIAL = "official";
+    public static final String STATUS_REJECTED = "rejected";
+
+    @Id
+    @GeneratedValue(strategy = GenerationType.IDENTITY)
+    private Long id;
+
+    @Column(name = "job_id", nullable = false)
+    private Long jobId;
+
+    @Column(name = "clan_id", nullable = false)
+    private Long clanId;
+
+    @Column(name = "branch_id")
+    private Long branchId;
+
+    @Column(name = "action_type", nullable = false)
+    private String actionType;
+
+    @Column(name = "target_scheme_id")
+    private Long targetSchemeId;
+
+    @Column(name = "scheme_name", nullable = false)
+    private String schemeName;
+
+    @Column(name = "poem_text", columnDefinition = "text")
+    private String poemText;
+
+    @Column(name = "start_generation", nullable = false)
+    private Integer startGeneration;
+
+    @Column(name = "is_default", nullable = false)
+    private Boolean isDefault;
+
+    @Column(name = "validation_enabled", nullable = false)
+    private Boolean validationEnabled;
+
+    @Column(name = "strict_mode", nullable = false)
+    private Boolean strictMode;
+
+    @Column(name = "generation_no", nullable = false)
+    private Integer generationNo;
+
+    @Column(name = "word", nullable = false)
+    private String word;
+
+    @Column(name = "description")
+    private String description;
+
+    @Column(name = "status", nullable = false)
+    private String status;
+
+    @Column(name = "created_by")
+    private Long createdBy;
+
+    @Column(name = "created_at", nullable = false)
+    private LocalDateTime createdAt;
+
+    @Column(name = "updated_at", nullable = false)
+    private LocalDateTime updatedAt;
+}
diff --git a/backend/genealogy-backend/src/main/java/com/genealogy/generation/repository/GenSchemeRepository.java b/backend/genealogy-backend/src/main/java/com/genealogy/generation/repository/GenSchemeRepository.java
index ad004be..7d1c844 100644
--- a/backend/genealogy-backend/src/main/java/com/genealogy/generation/repository/GenSchemeRepository.java
+++ b/backend/genealogy-backend/src/main/java/com/genealogy/generation/repository/GenSchemeRepository.java
@@ -2,10 +2,27 @@ package com.genealogy.generation.repository;
 
 import com.genealogy.generation.entity.GenerationSchemeEntity;
 import org.springframework.data.jpa.repository.JpaRepository;
+import org.springframework.data.jpa.repository.Query;
+import org.springframework.data.repository.query.Param;
 
 import java.util.List;
+import java.util.Optional;
 
 public interface GenSchemeRepository extends JpaRepository<GenerationSchemeEntity, Long> {
 
     List<GenerationSchemeEntity> findByClanIdOrderByIsDefaultDescIdAsc(Long clanId);
+
+    @Query("""
+            select scheme from GenerationSchemeEntity scheme
+            where scheme.clanId = :clanId
+              and ((:branchId is null and scheme.branchId is null) or scheme.branchId = :branchId)
+              and lower(scheme.schemeName) = lower(:schemeName)
+            """)
+    List<GenerationSchemeEntity> findByScopeAndName(
+            @Param("clanId") Long clanId,
+            @Param("branchId") Long branchId,
+            @Param("schemeName") String schemeName
+    );
+
+    Optional<GenerationSchemeEntity> findByIdAndClanId(Long id, Long clanId);
 }
