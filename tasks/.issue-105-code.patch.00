diff --git a/backend/genealogy-backend/src/main/java/com/genealogy/generation/entity/GenerationImportDraftEntity.java b/backend/genealogy-backend/src/main/java/com/genealogy/generation/entity/GenerationImportDraftEntity.java
new file mode 100644
index 0000000..35051d8
