tion upload() {
+    if (!clanId || !file) {
+      notify({ message: !clanId ? '请先选择所属宗族' : '请先选择填写后的模板文件' }, true);
+      return;
+    }
+    setLoading(true);
+    try {
+      const result = await apiClient.upload<ImportJobResult>(
+        `/clans/${clanId}/imports/generations${query()}`,
+        file
+      );
+      notify({ message: `字辈导入批次已创建：成功 ${result.successCount || 0} 条，失败 ${result.failureCount || 0} 条` });
+      setFile(null);
+      setPreview(null);
+      onBatchCreated();
+    } catch (error) {
+      notify({ message: (error as Error).message || '字辈导入批次创建失败' }, true);
+    } finally {
+      setLoading(false);
+    }
+  }
+
+  return (
+    <div>
+      <Card
+        title="字辈导入"
+        extra={(
+          <Space>
+            <Button disabled={loading} onClick={() => void downloadTemplate('csv')}>下载 CSV 模板</Button>
+            <Button disabled={loading} onClick={() => void downloadTemplate('xlsx')}>下载 XLSX 模板</Button>
+          </Space>
+        )}
+        style={{ marginTop: 16 }}
+      >
+        <Space direction="vertical" size="middle" style={{ width: '100%' }}>
+          <Alert
+            type="info"
+            showIcon
+            message="模板表头必须保持不变"
+            description="依次填写：方案名称、起始代次、代次、字辈文字、字辈诗、是否默认、启用校验、严格模式、说明。布尔字段只允许填写“是”或“否”。"
+          />
+          <Alert
+            type="info"
+            showIcon
+            message={`当前导入范围：${scopeText}`}
+            description="不选择支派时创建宗族通用方案；选择支派时创建或追加该支派的方案。审核通过前不会影响正式字辈数据。"
+          />
+          <Upload {...uploadProps}><Button disabled={!clanId}>上传填写后的模板</Button></Upload>
+          <Space wrap>
+            <Button disabled={loading || !clanId || !file} onClick={() => void previewFile()}>
+              {loading ? '处理中...' : '预览并校验'}
+            </Button>
+            <Button type="primary" disabled={loading || !clanId || !file} loading={loading} onClick={() => void upload()}>
+              创建导入批次
+            </Button>
+          </Space>
+        </Space>
+      </Card>
+
+      {preview ? (
+        <Card title="字辈导入预览" style={{ marginTop: 16 }}>
+          {(preview.errorCount || 0) > 0 ? (
+            <Alert type="warning" showIcon message={`发现 ${preview.errorCount} 条错误或冲突，可创建批次后逐行修正。`} style={{ marginBottom: 12 }} />
+          ) : null}
+          <Table<PreviewRow>
+            size="small"
+            bordered
+            rowKey={(row, index) => String(row.rowNo || index)}
+            dataSource={preview.rows || []}
+            pagination={false}
+            locale={{ emptyText: <Empty image={Empty.PRESENTED_IMAGE_SIMPLE} description="暂无预览数据" /> }}
+            columns={[
+              { key: 'rowNo', title: '行号', dataIndex: 'rowNo', width: 70 },
+              { key: 'schemeName', title: '方案名称', dataIndex: 'schemeName' },
+              { key: 'startGeneration', title: '起始代次', dataIndex: 'startGeneration', width: 100 },
+              { key: 'generationNo', title: '代次', dataIndex: 'generationNo', width: 80 },
+              { key: 'word', title: '字辈文字', dataIndex: 'word', width: 100 },
+              {
+                key: 'actionType', title: '处理策略', dataIndex: 'actionType', width: 110,
+                render: value => value === 'append_word' ? '追加明细' : value === 'create_scheme' ? '新建方案' : '-'
+              },
+              {
+                key: 'result', title: '校验结果', width: 100,
+                render: (_value, row) => row.errorMessage
+                  ? <Tag color={row.duplicated ? 'warning' : 'error'}>{row.duplicated ? '重复' : '错误'}</Tag>
+                  : <Tag color="success">通过</Tag>
+              },
+              { key: 'errorMessage', title: '错误原因', dataIndex: 'errorMessage' }
+            ]}
+            scroll={{ x: 'max-content' }}
+          />
+        </Card>
+      ) : null}
+    </div>
+  );
+}
