+    private void lockGenerationDrafts(
+            ImportJobEntity job,
+            List<ImportJobRowEntity> draftRows,
+            LocalDateTime now
+    ) {
+        List<GenerationImportDraftEntity> drafts = new ArrayList<>();
+        for (ImportJobRowEntity row : draftRows) {
+            if (!GenerationImportDraftEntity.TARGET_TYPE.equals(row.getDraftTargetType())) {
+                throw new BusinessException("IMPORT_JOB_DRAFT_TARGET_TYPE_MISMATCH", "字辈导入批次关联了错误的草稿类型");
+            }
+            GenerationImportDraftEntity draft = generationImportDraftRepository.findByIdAndJobId(targetId(row), job.getId())
+                    .orElseThrow(() -> new BusinessException("IMPORT_GENERATION_DRAFT_NOT_FOUND", "导入批次关联的字辈草稿不存在"));
+            if (!Objects.equals(draft.getClanId(), job.getClanId())
+                    || !Objects.equals(draft.getBranchId(), job.getBranchId())) {
+                throw new BusinessException("IMPORT_GENERATION_DRAFT_SCOPE_MISMATCH", "字辈草稿不属于当前宗族或支派范围");
+            }
+            requireDraftOrRejected(draft.getStatus(), "导入批次关联的字辈草稿当前不能提交审核");
+            draft.setStatus(GenerationImportDraftEntity.STATUS_PENDING_REVIEW);
+            draft.setUpdatedAt(now);
+            drafts.add(draft);
+        }
+        generationImportDraftRepository.saveAll(drafts);
+    }
+
