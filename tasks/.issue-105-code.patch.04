new file mode 100644
index 0000000..e2daf52
--- /dev/null
+++ b/backend/genealogy-backend/src/main/java/com/genealogy/imports/domain/GenerationImportTypeDefinition.java
@@ -0,0 +1,37 @@
+package com.genealogy.imports.domain;
+
+import org.springframework.stereotype.Component;
+
+import java.util.Set;
+
+@Component
+public class GenerationImportTypeDefinition implements ImportTypeDefinition {
+
+    public static final String TYPE = "generation";
+
+    @Override
+    public String importType() { return TYPE; }
+
+    @Override
+    public Set<String> supportedFormats() {
+        return Set.of(ImportJobDescriptor.FORMAT_CSV, ImportJobDescriptor.FORMAT_XLSX);
+    }
+
+    @Override
+    public String templateDefinition() { return "GenerationImportTemplateDefinition"; }
+
+    @Override
+    public String parser() { return "GenerationImportApplicationService#readImport"; }
+
+    @Override
+    public String rowValidator() { return "GenerationImportApplicationService#resolveDraft"; }
+
+    @Override
+    public String correctionSchema() { return "GenerationImportRowRetryRequest"; }
+
+    @Override
+    public String draftCreator() { return "GenerationImportApplicationService#createGenerationDraft"; }
+
+    @Override
+    public String reviewApplyHandler() { return "RevisionApplyService#import_job:generation"; }
+}
