@@ -0,0 +1,194 @@
+import { useEffect, useState } from 'react';
+import { Alert, Button, Card, Empty, Space, Table, Tag, Upload } from 'antd';
+import type { UploadProps } from 'antd';
+import { apiClient } from '../../shared/api/client';
+import { saveDownloadedBlob } from '../../shared/utils/download';
+
+type Props = {
+  notify: (data: unknown, error?: boolean) => void;
+  clanId: string;
+  branchId: string;
+  branchName: string;
+  onBatchCreated: () => void;
+};
+
+type PreviewRow = {
+  rowNo?: number;
+  schemeName?: string;
+  startGeneration?: number;
+  generationNo?: number;
+  word?: string;
+  actionType?: string;
+  duplicated?: boolean;
+  errorMessage?: string;
+};
+
+type PreviewResult = {
+  totalCount?: number;
+  validCount?: number;
+  duplicateCount?: number;
+  errorCount?: number;
+  rows?: PreviewRow[];
+};
+
+type ImportJobResult = { id?: number; totalCount?: number; successCount?: number; failureCount?: number };
+
+export function GenerationImportWorkspace({ notify, clanId, branchId, branchName, onBatchCreated }: Props) {
+  const [file, setFile] = useState<File | null>(null);
+  const [preview, setPreview] = useState<PreviewResult | null>(null);
+  const [loading, setLoading] = useState(false);
+
+  useEffect(() => {
+    setFile(null);
+    setPreview(null);
+  }, [clanId, branchId]);
+
+  const scopeText = branchId ? `支派“${branchName || '未命名支派'}”` : '宗族通用范围';
+
+  const uploadProps: UploadProps = {
+    accept: '.csv,.xlsx',
+    maxCount: 1,
+    beforeUpload: selected => {
+      setFile(selected as File);
+      setPreview(null);
+      return false;
+    },
+    onRemove: () => {
+      setFile(null);
+      setPreview(null);
+    },
+    fileList: file ? [{ uid: 'generation-import-file', name: file.name, status: 'done' }] : []
+  };
+
+  async function downloadTemplate(format: 'csv' | 'xlsx') {
+    try {
+      const response = await fetch(`/api/v1/imports/templates/generations.${format}`, { credentials: 'include' });
+      if (!response.ok) throw new Error('模板下载失败');
+      saveDownloadedBlob(await response.blob(), `generation-import-template.${format}`);
+    } catch (error) {
+      notify({ message: (error as Error).message || '模板下载失败' }, true);
+    }
+  }
+
+  function query() {
+    const params = new URLSearchParams();
+    if (branchId) params.set('branchId', branchId);
+    return params.toString() ? `?${params.toString()}` : '';
+  }
+
+  async function previewFile() {
+    if (!clanId || !file) {
+      notify({ message: !clanId ? '请先选择所属宗族' : '请先选择填写后的模板文件' }, true);
+      return;
+    }
+    setLoading(true);
+    try {
+      const result = await apiClient.upload<PreviewResult>(
+        `/clans/${clanId}/imports/generations/preview${query()}`,
+        file
+      );
+      setPreview(result);
+      notify({ message: `预览完成：${result.validCount || 0} 条可导入，${result.errorCount || 0} 条需修正` });
+    } catch (error) {
+      notify({ message: (error as Error).message || '字辈导入预览失败' }, true);
+    } finally {
+      setLoading(false);
+    }
+  }
+
+  async func