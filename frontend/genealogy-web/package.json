{
  "name": "genealogy-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5179",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4174",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "api:generate": "node ../../scripts/api/generate-frontend-client.mjs",
    "api:check": "bash ../../scripts/api/check-api-contract.sh",
    "test:members": "node --test src/features/members/memberPageModel.test.js",
    "test:auth": "node --test src/features/auth/authPageModel.test.js",
    "test:logs": "node --test src/features/logs/*.test.js",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@vitejs/plugin-react": "6.0.3",
    "antd": "6.5.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "7.0.2",
    "vite": "8.1.4"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3"
  }
}
