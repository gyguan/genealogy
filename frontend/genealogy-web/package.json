{
  "name": "genealogy-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5179",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4174",
    "api:check:culture": "node ../../scripts/api/check-culture-contract.mjs",
    "api:check:import-execution": "node ../../scripts/api/check-import-execution-contract.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "api:generate": "node ../../scripts/api/generate-all-api-contracts.mjs && node ../../scripts/api/generate-import-execution-types.mjs && node ../../scripts/api/generate-import-failure-types.mjs",
    "api:check": "bash ../../scripts/api/check-api-contract.sh",
    "test:tree": "rm -rf .tree-test && npx tsc src/features/tree/lineageGraphModel.ts src/features/tree/lineageRequestState.ts src/features/tree/lineageSemanticsModel.ts --ignoreConfig --target ES2020 --module ESNext --moduleResolution Bundler --outDir .tree-test --skipLibCheck && node --test src/features/tree/lineageGraphModel.test.mjs src/features/tree/lineageRequestState.test.mjs src/features/tree/lineageSemanticsModel.test.mjs; status=$?; rm -rf .tree-test; exit $status",
    "test:members": "node --test src/features/members/memberPageModel.test.js",
    "test:auth": "node --test src/features/auth/authPageModel.test.js",
    "test:logs": "node --test src/features/logs/*.test.js src/features/logs/*.test.mjs src/shared/navigation/*.test.mjs",
    "test:tracking-center": "node --test src/features/logs/trackingCenterModel.test.mjs",
    "test:culture": "playwright test e2e/culture-library.spec.ts",
    "test:migration": "playwright test e2e/migration-timeline.spec.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "antd": "latest",
    "dayjs": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "latest",
    "@types/react-dom": "latest"
  }
}