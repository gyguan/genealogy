{
  "paths": {
    "/api/v1/clans/{clanId}/culture-overview": {
      "get": {
        "operationId": "getCultureOverview",
        "tags": ["Culture"],
        "summary": "获取当前用户可见的宗族文化总览",
        "description": "只聚合当前用户可见且 official 的精选文化资料、迁徙事件和文化场所；每类结果均有数量上限。运行时由 Issue #172 实现。",
        "parameters": [
          {
            "name": "clanId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64" }
          }
        ],
        "responses": {
          "200": {
            "description": "文化总览",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiResponseCultureOverviewResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/v1/clans/{clanId}/culture-items": {
      "get": {
        "operationId": "listCultureItems",
        "tags": ["Culture"],
        "summary": "分页搜索宗族文化资料",
        "parameters": [
          { "name": "clanId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "keyword", "in": "query", "required": false, "schema": { "type": "string", "maxLength": 100 } },
          { "name": "category", "in": "query", "required": false, "schema": { "$ref": "#/components/schemas/CultureCategory" } },
          { "name": "branchId", "in": "query", "required": false, "schema": { "type": "integer", "format": "int64" } },
          { "name": "dataStatus", "in": "query", "required": false, "schema": { "$ref": "#/components/schemas/CultureDataStatus" } },
          { "name": "privacyLevel", "in": "query", "required": false, "schema": { "$ref": "#/components/schemas/CulturePrivacyLevel" } },
          { "name": "hasSource", "in": "query", "required": false, "schema": { "type": "boolean" } },
          { "name": "featuredOnHome", "in": "query", "required": false, "schema": { "type": "boolean" } },
          { "name": "pageNo", "in": "query", "required": false, "schema": { "type": "integer", "minimum": 1, "default": 1 } },
          { "name": "pageSize", "in": "query", "required": false, "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 20 } },
          { "name": "sort", "in": "query", "required": false, "schema": { "type": "string", "default": "updatedAt,desc" } }
        ],
        "responses": {
          "200": {
            "description": "权限过滤后的文化资料分页结果",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiResponseCultureItemPage" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      },
      "post": {
        "operationId": "createCultureItem",
        "tags": ["Culture"],
        "summary": "新增文化资料草稿",
        "parameters": [
          { "name": "clanId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CultureItemCreateRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "新建的文化资料草稿",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiResponseCultureItemDetailResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/v1/culture-items/{cultureItemId}": {
      "get": {
        "operationId": "getCultureItem",
        "tags": ["Culture"],
        "summary": "获取文化资料聚合详情",
