          { "name": "cultureItemId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }
        ],
        "responses": {
          "200": {
            "description": "文化资料详情、来源、附件、审核摘要和 allowedActions",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiResponseCultureItemDetailResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "description": "对象不存在、已删除或当前用户不可见" }
        }
      },
      "put": {
        "operationId": "updateCultureItem",
        "tags": ["Culture"],
        "summary": "更新草稿、驳回资料或创建正式资料变更申请",
        "parameters": [
          { "name": "cultureItemId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CultureItemUpdateRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "更新后的详情或变更申请结果",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiResponseCultureItemDetailResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "description": "对象不存在、已删除或当前用户不可见" },
          "409": { "description": "版本冲突或当前工作流状态不允许修改" }
        }
      },
      "delete": {
        "operationId": "deleteCultureItem",
        "tags": ["Culture"],
        "summary": "软删除草稿或创建正式资料删除申请",
        "parameters": [
          { "name": "cultureItemId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }
        ],
        "responses": {
          "200": {
            "description": "删除或删除申请结果",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiResponseCultureCommandResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "description": "对象不存在、已删除或当前用户不可见" },
          "409": { "description": "当前工作流状态不允许删除" }
        }
      }
    },
