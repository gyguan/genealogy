  "components": {
    "schemas": {
      "GenealogyTargetType": {
        "type": "string",
        "enum": [
          "person",
          "relationship",
          "branch",
          "clan",
          "generation_scheme",
          "generation_word",
          "source",
          "source_binding",
          "source_attachment",
          "import_job",
          "review_task",
          "culture_item",
          "migration_event",
          "culture_site"
        ]
      },
      "CultureCategory": {
        "type": "string",
        "enum": [
          "surname_origin",
          "hall_name",
          "commandery",
          "family_instruction",
          "ancestor_instruction",
          "clan_rule",
          "genealogy_preface",
          "genealogy_rule",
          "person_story",
          "custom_tradition",
          "other"
        ]
      },
      "CultureSiteType": {
        "type": "string",
        "enum": ["ancestral_hall", "ancestral_home", "cemetery", "memorial", "other"]
      },
      "CultureDataStatus": {
        "type": "string",
        "enum": ["draft", "pending_review", "official", "rejected", "archived"]
      },
      "CultureConfidenceLevel": {
        "type": "string",
        "enum": ["high", "medium", "low", "unknown"]
      },
      "CulturePrivacyLevel": {
        "type": "string",
        "enum": ["public", "clan_only", "branch_only", "relatives_only", "private", "sealed"]
      },
      "CultureSensitiveLevel": {
        "type": "string",
        "enum": ["normal", "sensitive", "highly_sensitive"]
      },
      "CultureScopeResponse": {
