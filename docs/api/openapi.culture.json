          "403": { "$ref": "#/components/responses/Forbidden" },
          "409": { "description": "重复提交或当前状态不允许提交" }
        }
      }
    },
    "/api/v1/culture-items/{cultureItemId}/archive": {
      "post": {
        "operationId": "archiveCultureItem",
        "tags": ["Culture"],
        "summary": "归档文化资料或创建正式资料归档申请",
        "parameters": [
          { "name": "cultureItemId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }
