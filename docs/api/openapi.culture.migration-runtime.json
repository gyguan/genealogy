{
  "paths": {
    "/api/v1/clans/{clanId}/migration-events": {
      "get": {
        "operationId": "listMigrationEvents",
        "tags": ["Culture"],
        "summary": "分页搜索当前用户可见的迁徙事件",
        "description": "权限、支派子树和隐私过滤在数据库分页之前完成；历史时期仅作为文本筛选，不推断年代。",
        "parameters": [
          { "name": "clanId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64", "minimum": 1 } },
          { "name": "keyword", "in": "query", "required": false, "schema": { "type": "string", "maxLength": 100 } },
          { "name": "branchId", "in": "query", "required": false, "schema": { "type": "integer", "format": "int64", "minimum": 1 } },
          { "name": "fromLocation", "in": "query", "required": false, "schema": { "type": "string", "maxLength": 100 } },
          { "name": "toLocation", "in": "query", "required": false, "schema": { "type": "string", "maxLength": 100 } },
          { "name": "migrationTimeText", "in": "query", "required": false, "schema": { "type": "string", "maxLength": 100 } },
          { "name": "founderPersonId", "in": "query", "required": false, "schema": { "type": "integer", "format": "int64", "minimum": 1 } },
          { "name": "dataStatus", "in": "query", "required": false, "schema": { "$ref": "#/components/schemas/CultureDataStatus" } },
          { "name": "privacyLevel", "in": "query", "required": false, "schema": { "$ref": "#/components/schemas/CulturePrivacyLevel" } },
          { "name": "hasSource", "in": "query", "required": false, "schema": { "type": "boolean" } },
          { "name": "pageNo", "in": "query", "required": false, "schema": { "type": "integer", "minimum": 1, "default": 1 } },
          { "name": "pageSize", "in": "query", "required": false, "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 20 } },
          { "name": "sort", "in": "query", "required": false, "schema": { "type": "string", "default": "sequenceNo,asc" } }
        ],
        "responses": {
          "200": { "description": "权限过滤后的迁徙事件分页结果", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponseMigrationEventPage" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      },
      "post": {
        "operationId": "createMigrationEvent",
        "tags": ["Culture"],
        "summary": "新增迁徙事件草稿",
        "parameters": [{ "name": "clanId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64", "minimum": 1 } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MigrationEventCreateRequest" } } } },
        "responses": {
          "200": { "description": "新建的迁徙事件草稿", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponseMigrationEventDetailResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "409": { "description": "同一支派迁徙顺序冲突" }
        }
      }
    },
    "/api/v1/migration-events/{migrationEventId}": {
      "get": {
        "operationId": "getMigrationEvent",
        "tags": ["Culture"],
        "summary": "获取迁徙事件聚合详情",
        "parameters": [{ "name": "migrationEventId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64", "minimum": 1 } }],
        "responses": {
          "200": { "description": "迁徙事件、支派、始迁祖、来源、审核摘要和 allowedActions", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponseMigrationEventDetailResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "description": "对象不存在、已删除或当前用户不可见" }
        }
      },
      "put": {
        "operationId": "updateMigrationEvent",
        "tags": ["Culture"],
        "summary": "更新草稿、驳回事件或创建正式事件变更申请",
        "parameters": [{ "name": "migrationEventId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64", "minimum": 1 } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MigrationEventUpdateRequest" } } } },
        "responses": {
          "200": { "description": "更新后的详情或变更申请结果", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponseMigrationEventDetailResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "description": "对象不存在、已删除或当前用户不可见" },
          "409": { "description": "顺序冲突、版本冲突或当前工作流状态不允许修改" }
        }
      },
      "delete": {
        "operationId": "deleteMigrationEvent",
        "tags": ["Culture"],
        "summary": "软删除迁徙草稿或创建正式事件删除申请",
        "parameters": [{ "name": "migrationEventId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64", "minimum": 1 } }],
        "responses": {
          "200": { "description": "删除或删除申请结果", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponseCultureCommandResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "description": "对象不存在、已删除或当前用户不可见" },
          "409": { "description": "当前工作流状态不允许删除" }
        }
      }
    },
    "/api/v1/migration-events/{migrationEventId}/submit-review": {
      "post": {
        "operationId": "submitMigrationEventReview",
        "tags": ["Culture"],
        "summary": "提交迁徙事件审核",
        "parameters": [{ "name": "migrationEventId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64", "minimum": 1 } }],
        "requestBody": { "required": false, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CultureSubmitReviewRequest" } } } },
        "responses": {
          "200": { "description": "审核提交结果", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponseCultureCommandResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "409": { "description": "重复提交或当前状态不允许提交" }
        }
      }
    },
    "/api/v1/migration-events/{migrationEventId}/archive": {
      "post": {
        "operationId": "archiveMigrationEvent",
        "tags": ["Culture"],
        "summary": "归档迁徙事件或创建正式事件归档申请",
        "parameters": [{ "name": "migrationEventId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64", "minimum": 1 } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CultureArchiveRequest" } } } },
        "responses": {
          "200": { "description": "归档或归档申请结果", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponseCultureCommandResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "description": "对象不存在、已删除或当前用户不可见" },
          "409": { "description": "当前状态不允许归档" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "MigrationEventCreateRequest": {
        "type": "object",
        "required": ["branchId", "sequenceNo", "fromLocation", "toLocation", "confidenceLevel", "privacyLevel", "sensitiveLevel"],
        "properties": {
          "branchId": { "type": "integer", "format": "int64", "minimum": 1 },
          "sequenceNo": { "type": "integer", "minimum": 1 },
          "fromLocation": { "type": "string", "minLength": 1, "maxLength": 500 },
          "toLocation": { "type": "string", "minLength": 1, "maxLength": 500 },
          "migrationTimeText": { "type": "string", "maxLength": 200, "nullable": true },
          "founderPersonId": { "type": "integer", "format": "int64", "minimum": 1, "nullable": true },
          "reason": { "type": "string", "maxLength": 1000, "nullable": true },
          "description": { "type": "string", "maxLength": 200000, "nullable": true },
          "confidenceLevel": { "$ref": "#/components/schemas/CultureConfidenceLevel" },
          "privacyLevel": { "$ref": "#/components/schemas/CulturePrivacyLevel" },
          "sensitiveLevel": { "$ref": "#/components/schemas/CultureSensitiveLevel" }
        }
      }
    }
  }
}
