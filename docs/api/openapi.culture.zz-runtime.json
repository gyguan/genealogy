{
  "components": {
    "schemas": {
      "CultureItemCreateRequest": {
        "type": "object",
        "required": ["category", "title", "confidenceLevel", "privacyLevel", "sensitiveLevel", "featuredOnHome", "sortOrder"],
        "properties": {
          "branchId": { "type": "integer", "format": "int64", "minimum": 1, "nullable": true },
          "category": { "$ref": "#/components/schemas/CultureCategory" },
          "title": { "type": "string", "minLength": 1, "maxLength": 200 },
          "summary": { "type": "string", "maxLength": 1000, "nullable": true },
          "content": { "type": "string", "maxLength": 200000, "nullable": true },
          "historicalPeriod": { "type": "string", "maxLength": 200, "nullable": true },
          "locationText": { "type": "string", "maxLength": 500, "nullable": true },
          "confidenceLevel": { "$ref": "#/components/schemas/CultureConfidenceLevel" },
          "privacyLevel": { "$ref": "#/components/schemas/CulturePrivacyLevel" },
          "sensitiveLevel": { "$ref": "#/components/schemas/CultureSensitiveLevel" },
          "featuredOnHome": { "type": "boolean" },
          "sortOrder": { "type": "integer", "minimum": 0 }
        }
      },
      "CultureItemSummaryResponse": {
        "type": "object",
        "required": [
          "id",
          "scope",
          "category",
          "title",
          "confidenceLevel",
          "privacyLevel",
          "sensitiveLevel",
          "dataStatus",
          "featuredOnHome",
          "sortOrder",
          "sourceCount",
          "attachmentCount",
          "reviewCount",
          "allowedActions",
          "version",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "scope": { "$ref": "#/components/schemas/CultureScopeResponse" },
          "category": { "$ref": "#/components/schemas/CultureCategory" },
          "title": { "type": "string" },
          "summary": { "type": "string", "nullable": true },
          "historicalPeriod": { "type": "string", "nullable": true },
          "locationText": { "type": "string", "nullable": true },
          "confidenceLevel": { "$ref": "#/components/schemas/CultureConfidenceLevel" },
          "privacyLevel": { "$ref": "#/components/schemas/CulturePrivacyLevel" },
          "sensitiveLevel": { "$ref": "#/components/schemas/CultureSensitiveLevel" },
          "dataStatus": { "$ref": "#/components/schemas/CultureDataStatus" },
          "featuredOnHome": { "type": "boolean" },
          "sortOrder": { "type": "integer" },
          "sourceCount": { "type": "integer", "minimum": 0 },
          "attachmentCount": { "type": "integer", "minimum": 0 },
          "reviewCount": { "type": "integer", "minimum": 0 },
          "allowedActions": { "type": "array", "items": { "type": "string" } },
          "version": { "type": "integer", "format": "int64" },
          "createdByName": { "type": "string", "nullable": true },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
