{
  "components": {
    "schemas": {
      "OperationLogResponse": {
        "type": "object",
        "required": [
          "id",
          "clanId",
          "actionType",
          "createdAt"
        ],
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "clanId": { "type": "integer", "format": "int64" },
          "actorId": { "type": "integer", "format": "int64", "nullable": true },
          "actionType": { "type": "string" },
          "targetType": { "type": "string", "nullable": true },
          "targetId": { "type": "integer", "format": "int64", "nullable": true },
          "summary": { "type": "string", "nullable": true },
          "detail": {
            "type": "string",
            "nullable": true,
            "description": "仅具备 operation_log.export 权限时返回；普通查看者为 null"
          },
          "requestId": {
            "type": "string",
            "nullable": true,
            "description": "仅具备 operation_log.export 权限时返回；普通查看者为 null"
          },
          "clientIp": {
            "type": "string",
            "nullable": true,
            "description": "仅具备 operation_log.export 权限时返回；普通查看者为 null"
          },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "OperationLogPage": {
        "type": "object",
        "required": ["records", "total", "pageNo", "pageSize", "totalPages"],
        "properties": {
          "records": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/OperationLogResponse" }
          },
          "total": { "type": "integer", "format": "int64" },
          "pageNo": { "type": "integer" },
          "pageSize": { "type": "integer" },
          "totalPages": { "type": "integer" }
        }
      },
      "OperationLogStatsItem": {
        "type": "object",
        "required": ["key", "count"],
        "properties": {
          "key": { "type": "string" },
          "count": { "type": "integer", "format": "int64" }
        }
      },
      "OperationLogStatsResponse": {
        "type": "object",
        "required": ["totalCount", "byActionType", "byActorId"],
        "properties": {
          "totalCount": { "type": "integer", "format": "int64" },
          "byActionType": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/OperationLogStatsItem" }
          },
          "byActorId": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/OperationLogStatsItem" }
          }
        }
      },
      "CheckTaskResponse": {
        "type": "object",
        "required": [
          "id",
          "clanId",
          "revisionId",
          "status",
          "createdAt"
        ],
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "clanId": { "type": "integer", "format": "int64" },
          "revisionId": { "type": "integer", "format": "int64" },
          "reviewLevel": { "type": "integer", "nullable": true },
          "reviewerId": { "type": "integer", "format": "int64", "nullable": true },
          "reviewerRole": { "type": "string", "nullable": true },
          "branchId": { "type": "integer", "format": "int64", "nullable": true },
          "status": { "type": "string" },
          "reviewComment": { "type": "string", "nullable": true },
          "reviewedAt": { "type": "string", "format": "date-time", "nullable": true },
          "createdAt": { "type": "string", "format": "date-time" },
          "targetType": { "type": "string", "nullable": true },
          "targetId": { "type": "integer", "format": "int64", "nullable": true },
          "title": { "type": "string", "nullable": true },
          "diffSummary": { "type": "string", "nullable": true },
          "submitterId": { "type": "integer", "format": "int64", "nullable": true },
          "submitTime": { "type": "string", "format": "date-time", "nullable": true }
        }
      },
      "AuditRecordResponse": {
        "type": "object",
        "required": [
          "id",
          "clanId",
          "targetType",
          "targetId",
          "changeType",
          "submitterId",
          "submitTime",
          "status"
        ],
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "clanId": { "type": "integer", "format": "int64" },
          "targetType": { "type": "string" },
          "targetId": { "type": "integer", "format": "int64" },
          "changeType": { "type": "string" },
          "oldPayload": { "type": "string", "nullable": true },
          "newPayload": { "type": "string", "nullable": true },
          "diffSummary": { "type": "string", "nullable": true },
          "submitterId": { "type": "integer", "format": "int64" },
          "submitTime": { "type": "string", "format": "date-time" },
          "status": { "type": "string" },
          "approvedAt": { "type": "string", "format": "date-time", "nullable": true },
          "rejectedReason": { "type": "string", "nullable": true }
        }
      },
      "ReviewTaskDetailResponse": {
        "type": "object",
        "required": ["task", "auditRecord"],
        "properties": {
          "task": { "$ref": "#/components/schemas/CheckTaskResponse" },
          "auditRecord": { "$ref": "#/components/schemas/AuditRecordResponse" }
        }
      },
      "ReviewDiffResponse": {
        "type": "object",
        "required": [
          "reviewTaskId",
          "revisionId",
          "clanId",
          "targetType",
          "targetId",
          "changeType",
          "fields"
        ],
        "properties": {
          "reviewTaskId": { "type": "integer", "format": "int64" },
          "revisionId": { "type": "integer", "format": "int64" },
          "clanId": { "type": "integer", "format": "int64" },
          "targetType": { "type": "string" },
          "targetId": { "type": "integer", "format": "int64" },
          "changeType": { "type": "string" },
          "diffSummary": { "type": "string", "nullable": true },
          "fields": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/FieldDiff" }
          }
        }
      },
      "FieldDiff": {
        "type": "object",
        "required": ["fieldName", "changeType"],
        "properties": {
          "fieldName": { "type": "string" },
          "beforeValue": { "type": "string", "nullable": true },
          "afterValue": { "type": "string", "nullable": true },
          "changeType": { "type": "string" }
        }
      }
    }
  }
}
