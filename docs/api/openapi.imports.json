{
  "paths": {
    "/api/v1/imports/templates/persons.csv": {
      "get": {
        "operationId": "downloadPersonImportCsvTemplate",
        "tags": ["Import"],
        "responses": {
          "200": {
            "description": "Strict person import CSV template",
            "content": {
              "text/csv": {
                "schema": { "type": "string", "format": "binary" }
              }
            }
          }
        }
      }
    },
    "/api/v1/imports/templates/persons.xlsx": {
      "get": {
        "operationId": "downloadPersonImportXlsxTemplate",
        "tags": ["Import"],
        "responses": {
          "200": {
            "description": "Strict person import XLSX template",
            "content": {
              "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet": {
                "schema": { "type": "string", "format": "binary" }
              }
            }
          }
        }
      }
    },
    "/api/v1/clans/{clanId}/imports/persons/preview": {
      "post": {
        "operationId": "previewPersonImport",
        "tags": ["Import"],
        "parameters": [
          { "name": "clanId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "branchId", "in": "query", "required": true, "schema": { "type": "integer", "format": "int64" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": { "$ref": "#/components/schemas/MultipartFileRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiResponseImportPreviewResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/clans/{clanId}/imports/persons.csv": {
      "post": {
        "operationId": "importPersonsAsJob",
        "tags": ["Import"],
        "parameters": [
          { "name": "clanId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "branchId", "in": "query", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "confirmDuplicates", "in": "query", "required": false, "schema": { "type": "boolean", "default": false } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": { "$ref": "#/components/schemas/MultipartFileRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiResponseImportJobResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/clans/{clanId}/imports": {
      "get": {
        "operationId": "listImportJobs",
        "tags": ["Import"],
        "parameters": [
          { "name": "clanId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "branchId", "in": "query", "required": false, "schema": { "type": "integer", "format": "int64" } },
          { "name": "status", "in": "query", "required": false, "schema": { "type": "string", "enum": ["running", "completed", "partial_completed", "failed"] } },
          { "name": "importType", "in": "query", "required": false, "schema": { "type": "string", "enum": ["person_csv", "person_xlsx"] } },
          { "name": "pageNo", "in": "query", "required": false, "schema": { "type": "integer", "default": 1 } },
          { "name": "pageSize", "in": "query", "required": false, "schema": { "type": "integer", "default": 20, "maximum": 200 } }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiResponseImportJobPage" }
              }
            }
          }
        }
      }
    },
    "/api/v1/clans/{clanId}/imports/{jobId}": {
      "get": {
        "operationId": "getImportJob",
        "tags": ["Import"],
        "parameters": [
          { "name": "clanId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "jobId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiResponseImportJobResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/clans/{clanId}/imports/{jobId}/rows": {
      "get": {
        "operationId": "listImportJobRows",
        "tags": ["Import"],
        "parameters": [
          { "name": "clanId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "jobId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "status", "in": "query", "required": false, "schema": { "type": "string", "default": "failed", "enum": ["failed", "all", "invalid", "retry_failed", "draft_created", "excluded"] } },
          { "name": "pageNo", "in": "query", "required": false, "schema": { "type": "integer", "default": 1 } },
          { "name": "pageSize", "in": "query", "required": false, "schema": { "type": "integer", "default": 20, "maximum": 200 } }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiResponseImportJobRowPage" }
              }
            }
          }
        }
      }
    },
    "/api/v1/clans/{clanId}/imports/{jobId}/rows/{rowId}/retry": {
      "post": {
        "operationId": "retryPersonImportRow",
        "tags": ["Import"],
        "parameters": [
          { "name": "clanId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "jobId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "rowId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PersonImportRowRetryRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Retry result; validation failures are returned as retry_failed row state.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiResponseImportJobRowResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ImportPreviewRowResponse": {
        "type": "object",
        "properties": {
          "rowNo": { "type": "integer" },
          "name": { "type": "string" },
          "gender": { "type": "string" },
          "generationNo": { "type": "integer" },
          "generationWord": { "type": "string" },
          "branchId": { "type": "integer", "format": "int64" },
          "birthDate": { "type": "string", "format": "date" },
          "isLiving": { "type": "boolean" },
          "duplicated": { "type": "boolean" },
          "duplicateCount": { "type": "integer" },
          "errorMessage": { "type": "string" },
          "rawData": { "type": "string" }
        }
      },
      "ImportPreviewResponse": {
        "type": "object",
        "properties": {
          "totalCount": { "type": "integer" },
          "validCount": { "type": "integer" },
          "duplicateCount": { "type": "integer" },
          "errorCount": { "type": "integer" },
          "rows": { "type": "array", "items": { "$ref": "#/components/schemas/ImportPreviewRowResponse" } }
        }
      },
      "ImportRowErrorResponse": {
        "type": "object",
        "properties": {
          "rowNo": { "type": "integer" },
          "errorMessage": { "type": "string" },
          "rawData": { "type": "string" }
        }
      },
      "ImportJobSummaryResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "importType": { "type": "string" },
          "originalFilename": { "type": "string" },
          "totalCount": { "type": "integer" },
          "successCount": { "type": "integer" },
          "failureCount": { "type": "integer" },
          "status": { "type": "string" },
          "errorSummary": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "ImportJobResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "clanId": { "type": "integer", "format": "int64" },
          "branchId": { "type": "integer", "format": "int64" },
          "importType": { "type": "string" },
          "originalFilename": { "type": "string" },
          "totalCount": { "type": "integer" },
          "successCount": { "type": "integer" },
          "failureCount": { "type": "integer" },
          "status": { "type": "string" },
          "errorSummary": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "errors": { "type": "array", "items": { "$ref": "#/components/schemas/ImportRowErrorResponse" } }
        }
      },
      "ImportJobPage": {
        "type": "object",
        "properties": {
          "records": { "type": "array", "items": { "$ref": "#/components/schemas/ImportJobSummaryResponse" } },
          "total": { "type": "integer", "format": "int64" },
          "pageNo": { "type": "integer" },
          "pageSize": { "type": "integer" },
          "totalPages": { "type": "integer" }
        }
      },
      "PersonImportRowRetryRequest": {
        "type": "object",
        "required": ["expectedVersion"],
        "properties": {
          "name": { "type": "string" },
          "gender": { "type": "string", "enum": ["male", "female", "unknown"] },
          "generationNo": { "type": "integer" },
          "generationWord": { "type": "string" },
          "birthDate": { "type": "string", "format": "date" },
          "isLiving": { "type": "boolean" },
          "confirmDuplicates": { "type": "boolean", "default": false },
          "expectedVersion": { "type": "integer", "format": "int64" }
        }
      },
      "ImportJobRowResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "rowNo": { "type": "integer" },
          "rawData": { "type": "string" },
          "normalizedData": { "type": "object", "additionalProperties": true },
          "correctedData": { "type": "object", "additionalProperties": true },
          "rowStatus": { "type": "string", "enum": ["invalid", "retry_failed", "draft_created", "excluded"] },
          "errorCode": { "type": "string" },
          "errorMessage": { "type": "string" },
          "retryCount": { "type": "integer" },
          "draftCreated": { "type": "boolean" },
          "version": { "type": "integer", "format": "int64" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "ImportJobRowPage": {
        "type": "object",
        "properties": {
          "records": { "type": "array", "items": { "$ref": "#/components/schemas/ImportJobRowResponse" } },
          "total": { "type": "integer", "format": "int64" },
          "pageNo": { "type": "integer" },
          "pageSize": { "type": "integer" },
          "totalPages": { "type": "integer" }
        }
      },
      "ApiResponseImportPreviewResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "code": { "type": "string" },
          "message": { "type": "string" },
          "data": { "$ref": "#/components/schemas/ImportPreviewResponse" },
          "traceId": { "type": "string" }
        }
      },
      "ApiResponseImportJobResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "code": { "type": "string" },
          "message": { "type": "string" },
          "data": { "$ref": "#/components/schemas/ImportJobResponse" },
          "traceId": { "type": "string" }
        }
      },
      "ApiResponseImportJobPage": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "code": { "type": "string" },
          "message": { "type": "string" },
          "data": { "$ref": "#/components/schemas/ImportJobPage" },
          "traceId": { "type": "string" }
        }
      },
      "ApiResponseImportJobRowResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "code": { "type": "string" },
          "message": { "type": "string" },
          "data": { "$ref": "#/components/schemas/ImportJobRowResponse" },
          "traceId": { "type": "string" }
        }
      },
      "ApiResponseImportJobRowPage": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "code": { "type": "string" },
          "message": { "type": "string" },
          "data": { "$ref": "#/components/schemas/ImportJobRowPage" },
          "traceId": { "type": "string" }
        }
      }
    }
  }
}
