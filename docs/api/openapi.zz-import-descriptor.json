{
  "paths": {
    "/api/v1/clans/{clanId}/imports": {
      "get": {
        "operationId": "listImportJobs",
        "tags": ["Import"],
        "parameters": [
          { "name": "clanId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "branchId", "in": "query", "required": false, "schema": { "type": "integer", "format": "int64" } },
          { "name": "status", "in": "query", "required": false, "schema": { "type": "string", "enum": ["running", "completed", "partial_completed", "failed"] } },
          {
            "name": "importType",
            "in": "query",
            "required": false,
            "description": "Business import type. Legacy person_csv/person_xlsx values are accepted during the compatibility window.",
            "schema": { "type": "string", "enum": ["person", "relationship", "generation", "source", "person_csv", "person_xlsx"] }
          },
          { "name": "fileFormat", "in": "query", "required": false, "schema": { "type": "string", "enum": ["csv", "xlsx"] } },
          { "name": "pageNo", "in": "query", "required": false, "schema": { "type": "integer", "default": 1 } },
          { "name": "pageSize", "in": "query", "required": false, "schema": { "type": "integer", "default": 20, "maximum": 200 } }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiResponseImportJobPage" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ImportJobSummaryResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "importType": { "type": "string", "enum": ["person", "relationship", "generation", "source"] },
          "fileFormat": { "type": "string", "enum": ["csv", "xlsx"] },
          "legacyImportType": { "type": "string", "deprecated": true, "description": "Compatibility value such as person_csv. New clients use importType and fileFormat." },
          "originalFilename": { "type": "string" },
          "totalCount": { "type": "integer" },
          "successCount": { "type": "integer" },
          "failureCount": { "type": "integer" },
          "status": { "type": "string" },
          "errorSummary": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "processingStatus": { "type": "string", "enum": ["processing", "correction_required", "ready_for_review"] },
          "reviewStatus": { "type": "string", "enum": ["not_submitted", "pending", "approved", "rejected", "cancelled"] },
          "reviewRound": { "type": "integer" },
          "latestReviewTaskId": { "type": "integer", "format": "int64" }
        }
      },
      "ImportJobResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "clanId": { "type": "integer", "format": "int64" },
          "branchId": { "type": "integer", "format": "int64" },
          "importType": { "type": "string", "enum": ["person", "relationship", "generation", "source"] },
          "fileFormat": { "type": "string", "enum": ["csv", "xlsx"] },
          "legacyImportType": { "type": "string", "deprecated": true, "description": "Compatibility value such as person_csv. New clients use importType and fileFormat." },
          "originalFilename": { "type": "string" },
          "totalCount": { "type": "integer" },
          "successCount": { "type": "integer" },
          "failureCount": { "type": "integer" },
          "status": { "type": "string" },
          "errorSummary": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "errors": { "type": "array", "items": { "$ref": "#/components/schemas/ImportRowErrorResponse" } },
          "processingStatus": { "type": "string", "enum": ["processing", "correction_required", "ready_for_review"] },
          "reviewStatus": { "type": "string", "enum": ["not_submitted", "pending", "approved", "rejected", "cancelled"] },
          "reviewRound": { "type": "integer" },
          "latestReviewTaskId": { "type": "integer", "format": "int64" }
        }
      }
    }
  }
}
