{
  "paths": {
    "/clans/{clanId}/members": {
      "get": {
        "operationId": "listAggregatedClanMembers",
        "tags": ["MemberPermission"],
        "parameters": [
          { "name": "clanId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "keyword", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "roleCode", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "scopeType", "in": "query", "required": false, "schema": { "$ref": "#/components/schemas/MemberScopeType" } },
          { "name": "status", "in": "query", "required": false, "schema": { "$ref": "#/components/schemas/MembershipStatus" } },
          { "name": "pageNo", "in": "query", "required": false, "schema": { "type": "integer", "default": 1, "minimum": 1 } },
          { "name": "pageSize", "in": "query", "required": false, "schema": { "type": "integer", "default": 20, "minimum": 1, "maximum": 100 } }
        ],
        "responses": {
          "200": {
            "description": "Aggregated member page",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiResponseMemberAggregatePage" }
              }
            }
          }
        }
      }
    },
    "/clans/{clanId}/member-candidates": {
      "get": {
        "operationId": "searchMemberCandidates",
        "tags": ["MemberPermission"],
        "parameters": [
          { "name": "clanId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "keyword", "in": "query", "required": true, "schema": { "type": "string", "minLength": 2 } },
          { "name": "pageNo", "in": "query", "required": false, "schema": { "type": "integer", "default": 1, "minimum": 1 } },
          { "name": "pageSize", "in": "query", "required": false, "schema": { "type": "integer", "default": 20, "minimum": 1, "maximum": 50 } }
        ],
        "responses": {
          "200": {
            "description": "Privacy-safe candidate page",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiResponseMemberCandidatePage" }
              }
            }
          }
        }
      }
    },
    "/clans/{clanId}/grantable-roles": {
      "get": {
        "operationId": "listGrantableRoles",
        "tags": ["MemberPermission"],
        "parameters": [
          { "name": "clanId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }
        ],
        "responses": {
          "200": {
            "description": "Roles the current actor may grant",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiResponseGrantableRoleList" }
              }
            }
          }
        }
      }
    },
    "/clans/{clanId}/member-grants": {
      "post": {
        "operationId": "createMemberGrant",
        "tags": ["MemberPermission"],
        "parameters": [
          { "name": "clanId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateMemberGrantRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created member grant",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiResponseMemberGrant" }
              }
            }
          }
        }
      }
    },
    "/clans/{clanId}/member-grants/{grantId}": {
      "put": {
        "operationId": "updateMemberGrant",
        "tags": ["MemberPermission"],
        "parameters": [
          { "name": "clanId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "grantId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateMemberGrantRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated member grant",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiResponseMemberGrant" }
              }
            }
          }
        }
      }
    },
    "/clans/{clanId}/member-grants/{grantId}/revoke": {
      "post": {
        "operationId": "revokeMemberGrant",
        "tags": ["MemberPermission"],
        "parameters": [
          { "name": "clanId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "grantId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RevokeMemberGrantRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Grant revoked",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiResponseVoid" }
              }
            }
          }
        }
      }
    },
    "/clans/{clanId}/members/{membershipId}/status": {
      "patch": {
        "operationId": "updateClanMembershipStatus",
        "tags": ["MemberPermission"],
        "parameters": [
          { "name": "clanId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "membershipId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateMemberStatusRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated membership",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiResponseMemberAggregate" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "MemberScopeType": {
        "type": "string",
        "enum": ["clan", "branch_subtree"]
      },
      "MembershipStatus": {
        "type": "string",
        "enum": ["active", "disabled", "removed"]
      },
      "CreateMemberGrantRequest": {
        "type": "object",
        "required": ["userId", "roleCode", "scopeType", "scopeId", "reason"],
        "properties": {
          "userId": { "type": "integer", "format": "int64" },
          "roleCode": { "type": "string" },
          "scopeType": { "$ref": "#/components/schemas/MemberScopeType" },
          "scopeId": { "type": "integer", "format": "int64" },
          "reason": { "type": "string", "maxLength": 500 }
        }
      },
      "UpdateMemberGrantRequest": {
        "type": "object",
        "required": ["roleCode", "scopeType", "scopeId", "reason"],
        "properties": {
          "roleCode": { "type": "string" },
          "scopeType": { "$ref": "#/components/schemas/MemberScopeType" },
          "scopeId": { "type": "integer", "format": "int64" },
          "reason": { "type": "string", "maxLength": 500 }
        }
      },
      "RevokeMemberGrantRequest": {
        "type": "object",
        "required": ["reason"],
        "properties": {
          "reason": { "type": "string", "maxLength": 500 }
        }
      },
      "UpdateMemberStatusRequest": {
        "type": "object",
        "required": ["status", "reason"],
        "properties": {
          "status": { "$ref": "#/components/schemas/MembershipStatus" },
          "reason": { "type": "string", "maxLength": 500 }
        }
      },
      "MemberCandidateResponse": {
        "type": "object",
        "properties": {
          "userId": { "type": "integer", "format": "int64" },
          "displayName": { "type": "string" },
          "maskedAccount": { "type": "string" },
          "alreadyMember": { "type": "boolean" }
        }
      },
      "GrantableRoleResponse": {
        "type": "object",
        "properties": {
          "roleCode": { "type": "string" },
          "roleName": { "type": "string" },
          "description": { "type": "string" },
          "allowedScopeTypes": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/MemberScopeType" }
          },
          "riskLevel": { "type": "string", "enum": ["normal", "high"] }
        }
      },
      "MemberGrantResponse": {
        "type": "object",
        "properties": {
          "grantId": { "type": "integer", "format": "int64" },
          "roleCode": { "type": "string" },
          "roleName": { "type": "string" },
          "scopeType": { "$ref": "#/components/schemas/MemberScopeType" },
          "scopeId": { "type": "integer", "format": "int64" },
          "scopeName": { "type": "string" },
          "grantStatus": { "type": "string", "enum": ["active", "revoked"] },
          "grantedBy": { "type": "integer", "format": "int64" },
          "grantedAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" },
          "canEditGrant": { "type": "boolean" },
          "canRevokeGrant": { "type": "boolean" }
        }
      },
      "MemberAllowedActionsResponse": {
        "type": "object",
        "properties": {
          "canGrantRole": { "type": "boolean" },
          "canEditGrant": { "type": "boolean" },
          "canRevokeGrant": { "type": "boolean" },
          "canDisableMember": { "type": "boolean" },
          "canViewHistory": { "type": "boolean" }
        }
      },
      "MemberAggregateResponse": {
        "type": "object",
        "properties": {
          "membershipId": { "type": "integer", "format": "int64" },
          "userId": { "type": "integer", "format": "int64" },
          "displayName": { "type": "string" },
          "maskedAccount": { "type": "string" },
          "membershipStatus": { "$ref": "#/components/schemas/MembershipStatus" },
          "joinedAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" },
          "grants": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/MemberGrantResponse" }
          },
          "allowedActions": { "$ref": "#/components/schemas/MemberAllowedActionsResponse" }
        }
      },
      "MemberAggregatePage": {
        "type": "object",
        "properties": {
          "records": { "type": "array", "items": { "$ref": "#/components/schemas/MemberAggregateResponse" } },
          "total": { "type": "integer", "format": "int64" },
          "pageNo": { "type": "integer" },
          "pageSize": { "type": "integer" },
          "totalPages": { "type": "integer" }
        }
      },
      "MemberCandidatePage": {
        "type": "object",
        "properties": {
          "records": { "type": "array", "items": { "$ref": "#/components/schemas/MemberCandidateResponse" } },
          "total": { "type": "integer", "format": "int64" },
          "pageNo": { "type": "integer" },
          "pageSize": { "type": "integer" },
          "totalPages": { "type": "integer" }
        }
      },
      "ApiResponseMemberAggregatePage": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "code": { "type": "string" },
          "message": { "type": "string" },
          "data": { "$ref": "#/components/schemas/MemberAggregatePage" },
          "traceId": { "type": "string" }
        }
      },
      "ApiResponseMemberCandidatePage": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "code": { "type": "string" },
          "message": { "type": "string" },
          "data": { "$ref": "#/components/schemas/MemberCandidatePage" },
          "traceId": { "type": "string" }
        }
      },
      "ApiResponseGrantableRoleList": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "code": { "type": "string" },
          "message": { "type": "string" },
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/GrantableRoleResponse" } },
          "traceId": { "type": "string" }
        }
      },
      "ApiResponseMemberGrant": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "code": { "type": "string" },
          "message": { "type": "string" },
          "data": { "$ref": "#/components/schemas/MemberGrantResponse" },
          "traceId": { "type": "string" }
        }
      },
      "ApiResponseMemberAggregate": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "code": { "type": "string" },
          "message": { "type": "string" },
          "data": { "$ref": "#/components/schemas/MemberAggregateResponse" },
          "traceId": { "type": "string" }
        }
      },
      "ApiResponseVoid": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "code": { "type": "string" },
          "message": { "type": "string" },
          "data": { "nullable": true },
          "traceId": { "type": "string" }
        }
      }
    }
  }
}
